ps(subset='all', categories=['comp.graphics', 'sci.space', 'rec.sport.hockey'],remove=('headers', 'footers', 'quotes'))\n","X_train, X_test, y_train, y_test = train_test_split(\n","    data.data, data.target, test_size=0.2, random_state=42\n",")"],"metadata":{"id":"qzS9nlewZDR1"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["Определим функцию `objective`.\n","\n","В качестве интересующих нас гиперпараметров выберем не только гиперпараметры градиентного бустинга, но и метод векторизации. Выбирать будем между *bag of words*, представленным классом `CountVectorizer`, и *Tf-Idf*, представленным классом `TfidfVectorizer`. Для каждого из них будем выбирать также `ngram_range`.\n","\n","Итого, будем выбирать следующие гиперпараметры:\n","\n","* n_estimators\n","* max_depth\n","* learning_rate\n","* vectorizer\n","* use_ngrams (1 или 2)"],"metadata":{"id":"EWTYvzkebKx0"}},{"cell_type":"code","source":["# 2. Функция objective\n","def objective(trial):\n","    # Выбор векторизатора\n","    vectorizer_name = trial.suggest_categorical(\"vectorizer\", [\"count\", \"tfidf\"])\n","    use_ngrams = trial.suggest_categorical(\"use_ngrams\", [True, False])\n","    ngram_range = (1, 2) if use_ngrams else (1, 1)\n","\n","    if vectorizer_name == \"count\":\n","        vectorizer = CountVectorizer(ngram_range=ngram_range, stop_words=\"english\")\n","    else:\n","        vectorizer = TfidfVectorizer(ngram_range=ngram_range, stop_words=\"english\")\n","\n","    # Гиперпараметры XGBoost\n","    n_estimators = trial.suggest_int(\"n_estimators\", 10, 90)\n","    max_depth = trial.suggest_int(\"max_depth\", 3, 10)\n","    learning_rate = trial.suggest_float(\"learning_rate\", 0.01, 0.3, log=True)\n","\n","    # Векторизация текста\n","    X_train_vec = vectorizer.fit_transform(X_train)\n","    X_test_vec = vectorizer.transform(X_test)\n","\n","    # Обучение модели\n","    model = XGBClassifier(\n","        n_estimators=n_estimators,\n","        max_depth=max_depth,\n","        learning_rate=learning_rate,\n","        use_label_encoder=False,\n","        eval_metric='logloss',\n","        verbosity=0\n","    )\n","    model.fit(X_train_vec, y_train)\n","\n","    # Оценка точности\n","    preds = model.predict(X_test_vec)\n","    accuracy = accuracy_score(y_test, preds)\n","    return accuracy"],"metadata":{"id":"6464vat-bIIO"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["Теперь запустим подбор!\n","\n","**Warning:** следующая ячейка выполняется долго, поэтому лучше запускать её только имея достаточно времени."],"metadata":{"id":"dxY-4EMxcTP3"}},{"cell_type":"code","source":["study = optuna.create_study(direction=\"maximize\")\n","study.optimize(objective, n_trials=30)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"KnFdJCVhcRWK","executionInfo":{"status":"ok","timestamp":1750342454594,"user_tz":-180,"elapsed":1212340,"user":{"displayName":"Сергей Артамонов","userId":"01556864889479707561"}},"outputId":"c7ce8bab-d3ea-4faf-9942-f246a489bf24"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["[I 2025-06-19 13:54:02,161] A new study created in memory with name: no-name-50371152-5924-4606-93f5-64e9198b866b\n","[I 2025-06-19 13:54:41,407] Trial 0 finished with value: 0.8226351351351351 and parameters: {'vectorizer': 'tfidf', 'use_ngrams': False, 'n_estimators': 54, 'max_depth': 9, 'learning_rate': 0.03804854239228438}. Best is trial 0 with value: 0.8226351351351351.\n","[I 2025-06-19 13:56:48,322] Trial 1 finished with value: 0.7820945945945946 and parameters: {'vectorizer': 'tfidf', 'use_ngrams': True, 'n_estimators': 53, 'max_depth': 9, 'learning_rate': 0.02595879671075342}. Best is trial 0 with value: 0.8226351351351351.\n","[I 2025-06-19 13:58:09,751] Trial 2 finished with value: 0.8445945945945946 and parameters: {'vectorizer': 'tfidf', 'use_ngrams': True, 'n_estimators': 62, 'max_depth': 7, 'learning_rate': 0.08649707953718314}. Best is trial 2 wit